---
// src/pages/404.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
---

<BaseLayout title="404 · Página no encontrada">
  <section class="section section--404">
    <div class="container">
      <Card as="article" class="error-card">
        <div class="card__body error-card__body">
          <!-- Icono/emoji con fondo suave -->
          <div class="error-card__icon" aria-hidden="true">🧭</div>

          <h1 class="error-card__title">404</h1>

          <p class="muted error-card__text">
            No encontramos esta página. Vuelve al inicio o usa el buscador del blog.
          </p>

          <div class="stack error-card__actions">
            <Button href="/" variant="primary">Volver al inicio</Button>
            <p class="error-card__links">
              <small>
                ¿Buscabas <a class="link" href="/projects">Proyectos</a> o
                <a class="link" href="/blog">Blog</a>?
              </small>
            </p>
          </div>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
