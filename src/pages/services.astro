---
// src/pages/services.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Testimonial from "../components/Testimonial.astro";
import { buildMetaDescription, SERVICES_META_TITLE } from "../lib/seo";
import { SITE } from "../lib/config";
import { testimonials } from "../lib/testimonials";

const pageTitle = "Servicios";
const metaTitle = SERVICES_META_TITLE;
const metaDescription = buildMetaDescription(
  "Auditoría gratuita de rendimiento web con informe base en 48–72h y opción de informe completo. Tres packs cerrados: Corrección, Optimización y Excelencia.",
  "Solicita la auditoría gratuita o pide presupuesto cerrado."
);

const canonical = new URL("/services/", SITE.url).href;
const personId = `${SITE.url}#persona`;

const siteEnv = import.meta.env.PUBLIC_SITE_ENV ?? "development";
const isProductionSite = siteEnv === "production";
const publishedTestimonials = testimonials.filter((t) => !t.draft);
const showTestimonialsSection = !isProductionSite || publishedTestimonials.length > 0;
const testimonialsToShow = isProductionSite ? publishedTestimonials : testimonials;
const organizationId = `${SITE.url}#organization`;
const servicesJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": canonical,
      "name": "Auditoría web y packs de mejora",
      "description": metaDescription,
      "url": canonical,
      "inLanguage": SITE.lang ?? "es",
      "isPartOf": { "@id": SITE.url },
      "publisher": { "@id": organizationId }
    },
    {
      "@type": "Service",
      "name": "Auditoría de rendimiento web",
      "description":
        "Auditoría gratuita con informe base y opción de informe completo (149€) para definir un plan priorizado P0/P1/P2.",
      "provider": { "@id": personId },
      "areaServed": "ES",
      "serviceType": "Web Performance, SEO técnico y UX"
    },
    {
      "@type": "Service",
      "name": "Pack Corrección",
      "description": "MVP técnico. Quick wins: imágenes críticas, scripts bloqueantes, CLS evidente, caché básica.",
      "provider": { "@id": personId },
      "areaServed": "ES",
      "offers": { "@type": "Offer", "price": "490", "priceCurrency": "EUR" }
    },
    {
      "@type": "Service",
      "name": "Pack Optimización",
      "description": "Lo necesario. Estrategia de carga, revisión INP, refactor secciones críticas y third-parties con criterio.",
      "provider": { "@id": personId },
      "areaServed": "ES",
      "offers": { "@type": "Offer", "price": "990", "priceCurrency": "EUR" }
    },
    {
      "@type": "Service",
      "name": "Pack Excelencia",
      "description": "Máximo nivel. Cambios profundos de arquitectura, design system completo, automatización y performance budget.",
      "provider": { "@id": personId },
      "areaServed": "ES",
      "offers": { "@type": "Offer", "price": "2490", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": SITE.url
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Servicios",
          "item": canonical
        }
      ]
    }
  ]
};
---

<BaseLayout title={pageTitle} metaTitle={metaTitle} description={metaDescription} ogImage="/og/services.png">
  <section class="section hero section--services-hero">
    <div class="wrap services-hero">
      <div class="stack" style="--stack-gap: 16px;">
        <p class="services-hero__kicker">Performance-first · SEO técnico · UX</p>
        <h1 class="services-hero__title">Servicios</h1>
        <p class="services-hero__lead">
          Una auditoría clara es la puerta de entrada. El objetivo: entender dónde estás, qué
          impacto tiene cada mejora y cuál es el plan más eficiente para tu web.
        </p>
        <div class="services-hero__actions">
          <Button href="/contact" variant="primary">Solicitar auditoría gratuita</Button>
          <Button href="#packs" variant="secondary">Ver packs de mejora</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--services-core">
    <div class="wrap">
      <div class="stack" style="--stack-gap: 24px;">
        <header class="section__header stack" style="--stack-gap: 8px;">
          <h2 class="h2 section__title">Auditoría gratuita</h2>
          <p class="services-text">
            Es el primer paso para entender tu situación real. Incluye revisión de métricas de campo,
            SEO técnico y experiencia de usuario, con un informe base claro en 48–72h.
          </p>
        </header>
        <div class="services-grid">
          <Card class="services-card">
            <div class="card__body stack" style="--stack-gap: 10px;">
              <h3 class="h3">Informe base <span class="pack-price-inline">gratis</span></h3>
              <ul class="services-list">
                <li>Resumen de métricas clave (LCP, INP, CLS).</li>
                <li>Hallazgos críticos de SEO técnico.</li>
                <li>Prioridades rápidas para desbloquear impacto.</li>
              </ul>
            </div>
          </Card>
          <Card class="services-card">
            <div class="card__body stack" style="--stack-gap: 10px;">
              <h3 class="h3">Informe completo <span class="pack-price-inline">149€</span></h3>
              <ul class="services-list">
                <li>Plan P0/P1/P2 con esfuerzo y dependencias.</li>
                <li>Recomendaciones de arquitectura y stack.</li>
                <li>Sesión de 30 min para revisar el plan.</li>
              </ul>
              <p class="services-note muted" style="margin: 0; font-size: 0.82rem;">
                Descontable si se contrata un pack.
              </p>
            </div>
          </Card>
        </div>
        <p class="services-note muted">
          Si encaja, la auditoría se convierte en el punto de partida para un pack de mejora con foco
          en rendimiento, SEO técnico y UX.
          <a href="/auditoria-web" class="services-audit-link">Ver en detalle qué incluye la auditoría →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt section--services-packs" id="packs">
    <div class="wrap">
      <div class="stack" style="--stack-gap: 24px;">
        <header class="section__header stack" style="--stack-gap: 8px;">
          <h2 class="h2 section__title">Packs de mejora</h2>
          <p class="services-text">
            Tres packs cerrados y comparables. Se activan cuando el diagnóstico confirma impacto
            claro y un retorno real para tu negocio.
          </p>
        </header>
        <div class="services-packs">

          <Card class="services-card pack-card">
            <div class="card__body stack" style="--stack-gap: 16px;">
              <div class="pack-header">
                <h3 class="h3 pack-name">Corrección</h3>
                <p class="pack-price">desde 490€</p>
              </div>
              <p class="pack-goal">MVP técnico. Quitar lo doloroso.</p>
              <div class="pack-section">
                <p class="pack-label">Incluye</p>
                <ul class="services-list">
                  <li>Imágenes críticas optimizadas.</li>
                  <li>Scripts bloqueantes eliminados.</li>
                  <li>CLS evidente corregido.</li>
                  <li>Caché básica configurada.</li>
                </ul>
              </div>
              <div class="pack-section">
                <p class="pack-label">Ideal para</p>
                <p class="muted pack-ideal">Presupuesto ajustado. Necesidad inmediata.</p>
              </div>
              <Button href="/contact" variant="secondary" class="pack-cta">Pedir presupuesto cerrado</Button>
            </div>
          </Card>

          <Card class="services-card pack-card pack-card--popular">
            <div class="pack-badge">Más popular</div>
            <div class="card__body stack" style="--stack-gap: 16px;">
              <div class="pack-header">
                <h3 class="h3 pack-name">Optimización</h3>
                <p class="pack-price">desde 990€</p>
              </div>
              <p class="pack-goal">Lo necesario. Equilibrio coste/beneficio.</p>
              <div class="pack-section">
                <p class="pack-label">Incluye</p>
                <ul class="services-list">
                  <li>Todo lo del pack Corrección.</li>
                  <li>Estrategia de carga (fonts/critical CSS).</li>
                  <li>Revisión INP y refactor secciones críticas.</li>
                  <li>Third-parties gestionados con criterio.</li>
                </ul>
              </div>
              <div class="pack-section">
                <p class="pack-label">Ideal para</p>
                <p class="muted pack-ideal">La mayoría de webs que quieren resultados sólidos.</p>
              </div>
              <Button href="/contact" variant="primary" class="pack-cta">Pedir presupuesto cerrado</Button>
            </div>
          </Card>

          <Card class="services-card pack-card">
            <div class="card__body stack" style="--stack-gap: 16px;">
              <div class="pack-header">
                <h3 class="h3 pack-name">Excelencia</h3>
                <p class="pack-price">desde 2.490€</p>
              </div>
              <p class="pack-goal">Máximo nivel. Calidad por encima del ROI inmediato.</p>
              <div class="pack-section">
                <p class="pack-label">Incluye</p>
                <ul class="services-list">
                  <li>Todo lo del pack Optimización.</li>
                  <li>Cambios profundos de arquitectura.</li>
                  <li>Design system completo.</li>
                  <li>Automatización, observabilidad y performance budget.</li>
                </ul>
              </div>
              <div class="pack-section">
                <p class="pack-label">Ideal para</p>
                <p class="muted pack-ideal">Negocios que priorizan "lo mejor" y la escalabilidad.</p>
              </div>
              <Button href="/contact" variant="secondary" class="pack-cta">Pedir presupuesto cerrado</Button>
            </div>
          </Card>

        </div>
        {showTestimonialsSection && (
          <div class="stack" style="--stack-gap: 24px; margin-top: 32px;">
            <h2 id="testimonials-heading" class="h2 section__title">Lo que dicen sobre la auditoría</h2>
            <div class="grid grid--3" style="--stack-gap:16px">
              {testimonialsToShow.map((t) => (
                <Testimonial testimonial={t} />
              ))}
            </div>
          </div>
        )}
        <div class="services-cta">
          <Button href="/contact" variant="primary">Quiero mi auditoría gratuita</Button>
          <Button href="/contact" variant="secondary">Pedir presupuesto cerrado</Button>
        </div>
        <p class="services-note muted" style="margin-top: 24px; max-width: 64ch;">
          <strong>Capacidades adicionales:</strong> Si tu proyecto requiere integración con Salesforce u
          otras plataformas CRM, puedo valorarlo como parte de un encargo más amplio.
          <a href="/blog/tags/salesforce/">Ver artículos sobre Salesforce</a>.
        </p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(servicesJsonLd, null, 2)} />
</BaseLayout>

<style>
  .section--services-hero {
    padding-block: clamp(64px, 12vw, 140px);
  }

  .services-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(16px, 4vw, 32px);
  }

  .services-hero__kicker {
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  .services-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.5rem);
    line-height: 1.1;
    color: var(--color-heading);
    margin: 0;
  }

  .services-hero__lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 64ch;
  }

  .services-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .services-text {
    color: var(--color-text-muted);
    max-width: 64ch;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
  }

  .services-card {
    height: 100%;
  }

  .services-grid .services-card .card__body {
    padding: 22px;
  }

  .services-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 6px;
    color: var(--color-text-muted);
  }

  .services-note {
    margin: 0;
    max-width: 70ch;
  }

  /* Pack price inline (for audit cards) */
  .pack-price-inline {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-left: 6px;
    padding: 2px 8px;
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    vertical-align: middle;
  }

  /* Pack cards */
  .services-packs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    align-items: start;
  }

  .pack-card {
    position: relative;
  }

  .pack-card .card__body {
    padding: 24px;
  }

  .pack-card--popular {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent);
  }

  .pack-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: var(--color-charcoal-950, #1f2426);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 12px;
    border-radius: 20px;
    white-space: nowrap;
    z-index: 1;
  }

  .pack-card--popular .card__body {
    padding-top: 24px;
  }

  .pack-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .pack-name {
    margin: 0;
  }

  .pack-price {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-accent);
    white-space: nowrap;
    margin: 0;
  }

  .pack-goal {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    margin: 0;
    line-height: 1.4;
  }

  .pack-section {
    display: grid;
    gap: 6px;
  }

  .pack-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .pack-ideal {
    margin: 0;
    font-size: 0.9rem;
  }

  .pack-cta {
    width: 100%;
    text-align: center;
    justify-content: center;
    margin-top: 4px;
  }

  .services-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .services-audit-link {
    display: inline-block;
    margin-top: 8px;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.9rem;
    font-weight: 500;
  }
</style>
