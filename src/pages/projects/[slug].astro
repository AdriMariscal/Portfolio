---
// src/pages/projects/[slug].astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import BeforeAfter from "@/components/BeforeAfter.astro";
import type { Metric } from "@/components/BeforeAfter.astro";
import { SITE } from "@/lib/config";
import {
  buildHeadingTitle,
  buildMetaDescription,
  buildMetaTitle,
  SEO_KEYWORD
} from "@/lib/seo";

export async function getStaticPaths() {
  const entries = await getCollection("projects", ({ data }) => data.published !== false);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: {
      project: entry,
      metaTitle: buildMetaTitle(SEO_KEYWORD, entry.data.title ?? SITE.title),
      metaDescription: buildMetaDescription(
        entry.data.description ?? SITE.description,
        "Descubre el proyecto y pide una auditoría."
      ),
      headingTitle: buildHeadingTitle(entry.data.title ?? SITE.title)
    }
  }));
}

const { project, metaTitle, metaDescription, headingTitle } = Astro.props as {
  project: Awaited<ReturnType<typeof getCollection>>[number];
  metaTitle: string;
  metaDescription: string;
  headingTitle: string;
};

const { Content } = await project.render();
const data: any = project.data;

// utils
const fmtDate = (d: Date | string | undefined) => {
  if (!d) return undefined;
  try {
    const dd = typeof d === "string" ? new Date(d) : d;
    return dd.toLocaleDateString("es-ES", { day: "2-digit", month: "long", year: "numeric" });
  } catch { return String(d); }
};

// normaliza urls: null/"" => undefined
const normalizeUrl = (v: unknown) =>
  typeof v === "string" && v.trim() !== "" ? v : undefined;

// campos
const title: string = data.title;
const tags: string[] = Array.isArray(data.tags) ? data.tags : [];

const projectUrl = normalizeUrl(data.projectUrl);
const repoUrl = normalizeUrl(data.repoUrl);
const demoUrl = normalizeUrl(data.demoUrl);

// estado
const isActive: boolean =
  typeof data.active === "boolean"
    ? data.active
    : typeof data.status === "string"
      ? ["active", "activo", "activa"].includes(String(data.status).toLowerCase())
      : data.published !== false;

// before/after metrics
const beforeAfter: Metric[] = Array.isArray(data.beforeAfter) ? data.beforeAfter : [];

// changelog
type Change = { type?: string; text?: string };
type Release = { version?: string; date?: string; changes?: Change[] };
const changelog: Release[] = Array.isArray(data.changelog) ? data.changelog : [];
const latest = changelog.length ? changelog[0] : undefined;
const latestDate = latest?.date ? fmtDate(latest.date) : undefined;

const canonical = Astro.url?.href ?? new URL(`/projects/${project.slug}/`, SITE.url).href;
// Ruta relativa de la OG image — BaseLayout la resuelve con deployBase.
// Para JSON-LD se usa siempre la URL canónica de producción.
const ogImageRel = `/og/projects/${project.slug}.png`;
const ogImageCanonical = new URL(ogImageRel, SITE.url).href;
const organizationId = `${SITE.url}#organization`;
const personId = `${SITE.url}#persona`;
const toISO = (d: unknown) => {
  if (!d) return undefined;
  const dt = d instanceof Date ? d : new Date(String(d));
  const t = dt.getTime();
  return Number.isFinite(t) ? dt.toISOString() : undefined;
};
const datePublishedISO = toISO(data.date ?? null);
const projectJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CreativeWork",
      "@id": canonical,
      "name": title,
      "description": metaDescription,
      "url": canonical,
      "image": ogImageCanonical,
      "inLanguage": SITE.lang ?? "es",
      "author": { "@id": personId },
      "publisher": { "@id": organizationId },
      ...(datePublishedISO ? { "datePublished": datePublishedISO } : {}),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": SITE.url,
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Proyectos",
          "item": new URL("/projects/", SITE.url).href,
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": title,
          "item": canonical,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  metaTitle={metaTitle}
  description={metaDescription}
  ogImage={ogImageRel}
  ogImageAlt={title}
  twitterImage={ogImageRel}
  twitterImageAlt={title}
>
  <article class="section post project-detail">
    <!-- margen inferior ajustado a 24px -->
    <Card as="div" variant="soft" class="wrap post__card">
      <div class="post__body">
        <nav class="breadcrumb" aria-label="Ruta de navegación">
          <ol class="breadcrumb__list">
            <li class="breadcrumb__item"><a href="/">Inicio</a></li>
            <li class="breadcrumb__sep" aria-hidden="true">›</li>
            <li class="breadcrumb__item"><a href="/projects/">Proyectos</a></li>
            <li class="breadcrumb__sep" aria-hidden="true">›</li>
            <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{title}</li>
          </ol>
        </nav>
          <h1 class="post__title">{headingTitle}</h1>

        <p class="post__date project-detail__meta">
          <strong class="project-detail__meta-label">Estado:</strong>{" "}
          <Badge variant={isActive ? "active" : "inactive"}>
            {isActive ? "Activo" : "Inactivo"}
          </Badge>
          {latest?.version && (
            <>
              {" · "}<strong>Última versión:</strong> {latest.version}
              {latestDate && ` (${latestDate})`}
            </>
          )}
        </p>

          {(projectUrl || repoUrl || demoUrl) && (
          <div class="post__actions">
          {projectUrl && (
              <Button href={projectUrl} variant="secondary" size="sm" target="_blank" rel="noopener noreferrer">
                Ver proyecto →
              </Button>
            )}
            {repoUrl && (
              <Button href={repoUrl} variant="secondary" size="sm" target="_blank" rel="noopener noreferrer">
                Ver código
              </Button>
            )}
            {demoUrl && (
              <Button href={demoUrl} variant="secondary" size="sm" target="_blank" rel="noopener noreferrer">
                Ver demo
              </Button>
          )}
          </div>
          )}

        <div class="post__prose">
          <Content />
        </div>

        {tags?.length ? (
          <footer class="post__meta">
            <ul class="tags tags--sm tags--mt" aria-label="Tecnologías del proyecto">
              {tags.map((t) => (
                <li>
                  <a class="tag" href={`/blog/tags/${encodeURIComponent(t)}/`}>#{t}</a>
                </li>
              ))}
          </ul>
          </footer>
        ) : null}
      </div>
    </Card>
  </article>

  {/* Sección Antes/Después */}
  {beforeAfter.length ? (
    <article class="section section--tight post project-detail__before-after">
      <div class="wrap" aria-labelledby="before-after-title">
        <BeforeAfter metrics={beforeAfter} />
      </div>
    </article>
  ) : null}

  {/* Changelog con sección compacta y respiración inferior */}
  {changelog.length ? (
    <article class="section section--tight post project-detail__changelog">
      <div class="wrap" aria-labelledby="changelog-title">
            <h2 id="changelog-title" class="h3" style="margin:0 0 .75rem">Changelog</h2>

            {changelog.map((rel, i) => {
            const d = fmtDate(rel?.date);
              return (
              <Card as="article" variant="soft" style={i > 0 ? "margin-top: 1rem" : undefined}>
                  <div class="card__body">
                    <h3 class="h4" style="margin:0 0 .5rem">
                    {rel?.version}{d && ` (${d})`}
              </h3>
                  {Array.isArray(rel?.changes) && rel!.changes!.length ? (
                      <ul>
                      {rel!.changes!.map((c) => (
                  <li>
                          {c?.type ? <><strong>{c.type}</strong>{c?.text ? " " : ""}</> : null}
                            {c?.text}
                  </li>
                ))}
              </ul>
                  ) : null}
                  </div>
                </Card>
              );
            })}
          </div>
    </article>
  ) : null}

  <script
    type="application/ld+json"
    set:html={JSON.stringify(projectJsonLd, null, 2)}
  />
</BaseLayout>
