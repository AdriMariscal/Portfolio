---
// src/pages/contact.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Input from "../components/ui/Input.astro";
import { buildMetaDescription, buildMetaTitle, SEO_KEYWORD } from "../lib/seo";

const metaTitle = buildMetaTitle(SEO_KEYWORD, "Contacto");
const metaDescription = buildMetaDescription(
  "Contacta para mejorar rendimiento web, SEO técnico y UX con un plan claro y medible.",
  "Agenda tu auditoría gratuita hoy."
);
const hcaptchaSiteKey = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY ?? "";
---

<BaseLayout title="Contacto" metaTitle={metaTitle} description={metaDescription}>
  <main class="section section--contact">
    <div class="wrap">
      <!-- Encabezado con respiración -->
      <header class="contact__intro stack" style="--stack-gap: 6px;">
        <h1 class="h2 section__title section__title--page">Contacto</h1>
      <p class="muted">Cuéntame en qué te puedo ayudar.</p>
      </header>

      <!-- Formulario -->
      <Card
        as="form"
        class="contact__form"
        name="contact"
        method="POST"
        action="/thanks"
        data-contact-form
        aria-describedby="contact-privacy-note contact-error-message"
        novalidate
      >
        <div class="card__body stack" style="--stack-gap: 18px;">
        <label class="field">
          <span>Nombre</span>
          <Input
            type="text"
            name="name"
            autocomplete="name"
            placeholder="Tu nombre completo"
            aria-describedby="contact-name-error"
            required
          />
          <span
            id="contact-name-error"
            class="field__error muted"
            data-field-error="name"
            aria-live="polite"
            aria-atomic="true"
            hidden
          ></span>
        </label>

        <label class="field">
          <span>Email</span>
          <Input
            type="email"
            name="email"
            autocomplete="email"
            placeholder="tu@email.com"
            aria-describedby="contact-email-error"
            required
          />
          <span
            id="contact-email-error"
            class="field__error muted"
            data-field-error="email"
            aria-live="polite"
            aria-atomic="true"
            hidden
          ></span>
        </label>

        <label class="field">
          <span>Objetivo (opcional)</span>
          <Input
            type="text"
            name="goal"
            autocomplete="off"
            placeholder="Ej: mejorar conversiones, bajar LCP o lanzar en 6 semanas."
          />
        </label>

        <label class="field">
          <span>Presupuesto (opcional)</span>
          <Input
            type="text"
            name="budget"
            autocomplete="off"
            placeholder="Ej: 1.500–3.000 € o “por definir”."
          />
        </label>

        <label class="field">
          <span>Stack actual (opcional)</span>
          <Input
            type="text"
            name="stack"
            autocomplete="off"
            placeholder="Ej: WordPress, Webflow, Shopify, Astro."
          />
        </label>

        <label class="field">
          <span>Mensaje</span>
          <Input
            as="textarea"
            name="message"
            rows="6"
            placeholder="Cuéntame objetivos, plazos y si ya tienes web."
            aria-describedby="contact-message-error"
            required
          />
          <span
            id="contact-message-error"
            class="field__error muted"
            data-field-error="message"
            aria-live="polite"
            aria-atomic="true"
            hidden
          ></span>
        </label>

        <div class="h-captcha" data-sitekey={hcaptchaSiteKey}></div>

        <div class="contact__actions">
          <Button variant="primary" type="submit" block>
            Solicitar auditoría gratuita
          </Button>
          <p
            class="contact__success muted"
            data-contact-success
            role="status"
            aria-live="polite"
            hidden
          ></p>
          <p
            id="contact-error-message"
            class="contact__error muted"
            data-contact-error
            role="status"
            aria-live="polite"
            hidden
          >
            Revisa los campos marcados. Hay información obligatoria pendiente.
          </p>
          <p id="contact-privacy-note" class="contact__legal muted">
            Al enviar aceptas la
            <a class="link" href="/legal/privacidad">Política de privacidad</a>.
          </p>
        </div>
      </Card>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.querySelector('[data-contact-form]');
  const errorMessage = document.querySelector('[data-contact-error]');
  const successMessage = document.querySelector('[data-contact-success]');

  if (form && errorMessage && successMessage) {
    const requiredMessage =
      'Revisa los campos marcados. Hay información obligatoria pendiente.';
    const emailMessage =
      'Ese email no parece válido. Comprueba el formato e inténtalo de nuevo.';
    const defaultSuccessMessage =
      'Gracias por tu mensaje. En breve te respondo con los siguientes pasos.';
    const submitButton = form.querySelector('button[type="submit"]');

    const fields = Array.from(form.querySelectorAll('input, textarea'));
    const fieldErrors = new Map();
    form.querySelectorAll('[data-field-error]').forEach((node) => {
      if (node instanceof HTMLElement && node.dataset.fieldError) {
        fieldErrors.set(node.dataset.fieldError, node);
      }
    });

    const setFieldError = (field, message) => {
      if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) {
        return;
      }

      const errorNode = fieldErrors.get(field.name);
      if (!errorNode) {
        return;
      }

      if (message) {
        errorNode.textContent = message;
        errorNode.hidden = false;
        field.setAttribute('aria-invalid', 'true');
      } else {
        errorNode.textContent = '';
        errorNode.hidden = true;
        field.removeAttribute('aria-invalid');
      }
    };

    const updateValidity = (field) => {
      if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) {
        return;
      }

      if (field.validity.valueMissing) {
        field.setCustomValidity(requiredMessage);
        setFieldError(field, requiredMessage);
        return;
      }

      if (field instanceof HTMLInputElement && field.type === 'email' && field.validity.typeMismatch) {
        field.setCustomValidity(emailMessage);
        setFieldError(field, emailMessage);
        return;
      }

      field.setCustomValidity('');
      setFieldError(field, '');
    };

    const syncErrorMessage = () => {
      const firstInvalid = form.querySelector(':invalid');
      if (!firstInvalid) {
        errorMessage.hidden = true;
        return;
      }

      if (firstInvalid instanceof HTMLInputElement && firstInvalid.type === 'email') {
        errorMessage.textContent = emailMessage;
      } else {
        errorMessage.textContent = requiredMessage;
      }

      errorMessage.hidden = false;
    };

    form.addEventListener('input', (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement) {
        updateValidity(target);
      }

      if (form.checkValidity()) {
        errorMessage.hidden = true;
      }
    });
    form.addEventListener('submit', async (event) => {
      fields.forEach(updateValidity);
      if (!form.checkValidity()) {
        event.preventDefault();
        syncErrorMessage();
        const firstInvalid = form.querySelector(':invalid');
        if (firstInvalid && typeof firstInvalid.focus === 'function') {
          firstInvalid.focus();
        }
        return;
      }

      event.preventDefault();
      errorMessage.hidden = true;
      successMessage.hidden = true;

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.setAttribute('aria-busy', 'true');
      }

      try {
        const formData = new FormData(form);
        const payload = new URLSearchParams(formData);

        const response = await fetch('/.netlify/functions/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
          },
          body: payload.toString(),
        });

        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(data?.message || 'No se pudo enviar el formulario.');
        }

        successMessage.textContent = data?.message || defaultSuccessMessage;
        successMessage.hidden = false;
        form.reset();
        if (typeof window !== 'undefined' && window.hcaptcha?.reset) {
          window.hcaptcha.reset();
        }
      } catch (error) {
        errorMessage.textContent =
          error instanceof Error ? error.message : 'No se pudo enviar el formulario.';
        errorMessage.hidden = false;
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.removeAttribute('aria-busy');
        }
      }
    });

  }
</script>

<script src="https://js.hcaptcha.com/1/api.js" async defer></script>
