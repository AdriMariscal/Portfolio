---
// src/pages/contact.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Input from "../components/ui/Input.astro";
---

<BaseLayout title="Contacto · Adrián Mariscal" description="Cuéntame en qué te puedo ayudar.">
  <main class="section section--contact">
    <div class="wrap">
      <!-- Encabezado con respiración -->
      <header class="contact__intro stack" style="--stack-gap: 6px;">
        <h1 class="h2 section__title section__title--page">Contacto</h1>
      <p class="muted">Cuéntame en qué te puedo ayudar.</p>
      </header>

      <!-- Formulario -->
      <Card
        as="form"
        class="contact__form"
        name="contact"
        method="POST"
        action="/thanks"
        data-netlify="true"
        netlify-honeypot="bot-field"
        data-netlify-recaptcha="true"
        data-contact-form
        aria-describedby="contact-privacy-note contact-error-message"
        novalidate
      >
        <!-- Netlify -->
        <input type="hidden" name="form-name" value="contact" />
        <p hidden>
          <label>Don’t fill this out: <input name="bot-field" /></label>
        </p>

        <div class="card__body stack" style="--stack-gap: 18px;">
        <label class="field">
          <span>Nombre</span>
          <Input
            type="text"
            name="name"
            autocomplete="name"
            placeholder="Tu nombre completo"
            required
          />
        </label>

        <label class="field">
          <span>Email</span>
          <Input
            type="email"
            name="email"
            autocomplete="email"
            placeholder="tu@email.com"
            required
          />
        </label>

        <label class="field">
          <span>Mensaje</span>
          <Input
            as="textarea"
            name="message"
            rows="6"
            placeholder="Cuéntame objetivos, plazos y si ya tienes web."
            required
          />
        </label>

        <div data-netlify-recaptcha="true"></div>

        <div class="contact__actions">
          <Button variant="primary" type="submit" block>
            Solicitar auditoría gratuita
          </Button>
          <p
            id="contact-error-message"
            class="contact__error muted"
            data-contact-error
            role="status"
            aria-live="polite"
            hidden
          >
            Revisa los campos marcados. Hay información obligatoria pendiente.
          </p>
          <p id="contact-privacy-note" class="contact__legal muted">
            Al enviar aceptas la
            <a class="link" href="/legal/privacidad">Política de privacidad</a>.
          </p>
        </div>
      </Card>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.querySelector('[data-contact-form]');
  const errorMessage = document.querySelector('[data-contact-error]');

  if (form && errorMessage) {
    const requiredMessage =
      'Revisa los campos marcados. Hay información obligatoria pendiente.';
    const emailMessage =
      'Ese email no parece válido. Comprueba el formato e inténtalo de nuevo.';

    const fields = Array.from(form.querySelectorAll('input, textarea'));

    const updateValidity = (field) => {
      if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) {
        return;
      }

      if (field.validity.valueMissing) {
        field.setCustomValidity(requiredMessage);
        return;
      }

      if (field instanceof HTMLInputElement && field.type === 'email' && field.validity.typeMismatch) {
        field.setCustomValidity(emailMessage);
        return;
      }

      field.setCustomValidity('');
    };

    const syncErrorMessage = () => {
      const firstInvalid = form.querySelector(':invalid');
      if (!firstInvalid) {
        errorMessage.hidden = true;
        return;
      }

      if (firstInvalid instanceof HTMLInputElement && firstInvalid.type === 'email') {
        errorMessage.textContent = emailMessage;
      } else {
        errorMessage.textContent = requiredMessage;
      }

      errorMessage.hidden = false;
    };

    form.addEventListener('submit', (event) => {
      fields.forEach(updateValidity);
      if (!form.checkValidity()) {
        event.preventDefault();
        syncErrorMessage();
        const firstInvalid = form.querySelector(':invalid');
        if (firstInvalid && typeof firstInvalid.focus === 'function') {
          firstInvalid.focus();
        }
      }
    });

    form.addEventListener('input', (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement) {
        updateValidity(target);
      }

      if (form.checkValidity()) {
        errorMessage.hidden = true;
      }
    });
  }
</script>
