---
// src/pages/thanks.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import { buildMetaDescription, buildMetaTitle, SEO_KEYWORD } from "../lib/seo";

const metaTitle = buildMetaTitle(SEO_KEYWORD, "Gracias por tu mensaje");
const metaDescription = buildMetaDescription(
  "Confirmación de contacto para mejorar rendimiento web, SEO técnico y UX.",
  "Vuelve al inicio y descubre cómo ayudarte."
);
---

<BaseLayout title="¡Gracias!" metaTitle={metaTitle} description={metaDescription}>
  <section class="section section--thanks">
    <div class="wrap">
      <Card class="thanks__card">
        <div class="card__body thanks__body">
          <h1 class="thanks__title">¡Gracias!</h1>
          <p class="muted thanks__desc">He recibido tu mensaje. Te responderé lo antes posible.</p>
          <Button href="/" variant="secondary">Volver al inicio</Button>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
