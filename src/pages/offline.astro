---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sin conexión · Adrián Mariscal"
  metaTitle="Sin conexión · Adrián Mariscal"
  description="No hay conexión a Internet disponible."
  robots="noindex, nofollow"
>
  <section class="offline" aria-labelledby="offline-heading">
    <div class="offline__icon" aria-hidden="true">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="1" y1="1" x2="23" y2="23" />
        <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55" />
        <path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39" />
        <path d="M10.71 5.05A16 16 0 0 1 22.56 9" />
        <path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88" />
        <path d="M8.53 16.11a6 6 0 0 1 6.95 0" />
        <line x1="12" y1="20" x2="12.01" y2="20" />
      </svg>
    </div>
    <h1 id="offline-heading">Sin conexión</h1>
    <p>
      Parece que no tienes conexión a Internet en este momento.
      Comprueba tu conexión e inténtalo de nuevo.
    </p>
    <button class="btn btn--primary" onclick="window.location.reload()">
      Reintentar
    </button>
  </section>
</BaseLayout>

<style>
  .offline {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: 2rem;
    text-align: center;
    gap: 1.25rem;
  }
  .offline__icon {
    color: var(--color-text-muted);
    opacity: 0.6;
  }
  .offline h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-heading);
    margin: 0;
  }
  .offline p {
    max-width: 36ch;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
