---
// src/layouts/BaseLayout.astro

// Self-hosted fonts via Fontsource (all subsets, browser picks via unicode-range)
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/sora/600.css";
import "@fontsource/sora/700.css";
import "@fontsource/sora/800.css";

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { SITE, THEME } from "../lib/config";
import "../scripts/rum-core-web-vitals.ts";
import { pwaInfo } from "virtual:pwa-info";

type Props = {
  title?: string;
  metaTitle?: string;
  description?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  articleAuthor?: string;
  articleTags?: string[];
  articleSection?: string;
  robots?: string;
  twitterCreator?: string;
  twitterImage?: string;
  twitterImageAlt?: string;
  twitterCard?: string;
};

const {
  title = "Adrián Mariscal",
  metaTitle,
  description = SITE.description ??
    "Rendimiento web, SEO técnico y UX con Astro y Node.",
  ogDescription,
  ogImage,
  ogImageAlt,
  ogType,
  articleAuthor,
  articleTags,
  articleSection,
  robots,
  twitterCreator,
  twitterImage,
  twitterImageAlt,
  twitterCard,
} = Astro.props as Props;

const resolvedTitle = metaTitle ?? title;
const resolvedDescription = ogDescription ?? description;

// Canonical siempre apunta al dominio de producción (SITE.url),
// independientemente del entorno de deploy (dev, staging, preview).
const canonical = new URL(Astro.url?.pathname ?? "/", SITE.url).href;

// Detecta tipo automáticamente: 'article' en /blog/*, 'website' en el resto
const autoType = Astro.url?.pathname?.startsWith("/blog/") ? "article" : "website";
const type = ogType ?? autoType;

// Base para recursos estáticos: usa Astro.site (que en Netlify refleja el deploy
// actual: dev.adrianmariscal.es, preview-*.netlify.app, etc.) para que og:image
// y twitterImage sean fetcheables desde el entorno donde se desplegó la build.
const deployBase = Astro.site ?? SITE.url;

// Imagen OG (absoluta): prioriza prop > config por defecto
const rawImage = ogImage ?? SITE.ogImage ?? "/og-default.png";
const ogImageAbs = rawImage.startsWith("http")
  ? rawImage
  : new URL(rawImage, deployBase).href;
const resolvedOgAlt =
  ogImageAlt ?? SITE.ogImageAlt ?? `${SITE.title} · ${SITE.description}`;
const twitterRawImage = twitterImage ?? SITE.twitterImage ?? rawImage;
const twitterImageAbs = twitterRawImage.startsWith("http")
  ? twitterRawImage
  : new URL(twitterRawImage, deployBase).href;
const resolvedTwitterAlt =
  twitterImageAlt ?? SITE.twitterImageAlt ?? resolvedOgAlt;
const resolvedTwitterCard =
  twitterCard ??
  SITE.twitterCard ??
  (twitterImageAbs === ogImageAbs ? "summary_large_image" : "summary");

// Locale + site name
const locale = "es_ES";
const siteName = SITE.siteName ?? "Portfolio - Adrián Mariscal";
const organizationId = `${SITE.url}#organization`;
const personId = `${SITE.url}#persona`;
const organizationImage = SITE.ogImage ?? "/logos/logo_fondo_Charcoal950.png";
const organizationImageAbs = organizationImage.startsWith("http")
  ? organizationImage
  : new URL(organizationImage, SITE.url).href;
const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": SITE.url,
      "name": siteName,
      "url": SITE.url,
      "description": SITE.description,
      "inLanguage": SITE.lang ?? "es",
      "publisher": { "@id": organizationId },
    },
    {
      "@type": ["ProfessionalService", "LocalBusiness"],
      "@id": organizationId,
      "name": SITE.title,
      "url": SITE.url,
      "description": SITE.description,
      "image": organizationImageAbs,
      "logo": {
        "@type": "ImageObject",
        "url": organizationImageAbs,
      },
      "founder": { "@id": personId },
      "areaServed": "España",
      "priceRange": "€€",
    },
    {
      "@type": "Person",
      "@id": personId,
      "name": SITE.author,
      "url": SITE.url,
      "jobTitle": "Diseñador Web",
      "sameAs": [SITE.linkedin, SITE.github],
      "knowsAbout": [
        "Rendimiento web",
        "SEO técnico",
        "UX",
        "Astro",
        "Node.js",
      ],
      "worksFor": { "@id": organizationId },
    },
  ],
};
---

<!doctype html>
<html lang={SITE.lang ?? "es"} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
        <script is:inline type="module" src="/scripts/theme-init.js"></script>

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="theme-color" content={THEME.color} />
    <link rel="icon" type="image/svg+xml" href="/logos/favicon.svg" />
    <link rel="icon" type="image/png" sizes="500x500" href="/logos/favicon.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/pwa-192x192.png" />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <link rel="canonical" href={canonical} />
    {robots && <meta name="robots" content={robots} />}    


    <!-- Open Graph -->
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content={resolvedOgAlt} />

    {type === "article" && (
      <>
        <meta
          property="article:author"
          content={articleAuthor ?? SITE.author}
        />
        {Array.isArray(articleTags) &&
          articleTags.map((tag) => (
            <meta property="article:tag" content={tag} />
          ))}
        <meta
          property="article:section"
          content={articleSection ?? "Blog"}
        />
      </>
    )}    

    <!-- Twitter (compatible con X/Twitter cards) -->
    <meta name="twitter:card" content={resolvedTwitterCard} />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={twitterImageAbs} />
    <meta name="twitter:image:alt" content={resolvedTwitterAlt} />
    {twitterCreator && (
      <meta name="twitter:creator" content={twitterCreator} />
    )}

    <!-- Schema.org (WebSite + Person) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schemaOrg, null, 2)}
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      Saltar al contenido principal
    </a>

    <Header />
    <main
      id="main-content"
      tabindex="-1"
      aria-label="Contenido principal"
    >
      <slot />
    </main>
    <CookieConsent />
    <Footer />
    {/* RUM propio de Core Web Vitals (LCP/INP/CLS) */}
    <script>
      import "../scripts/rum-core-web-vitals.ts";
    </script>
    <script src="/src/pwa.ts"></script>
  </body>
</html>
