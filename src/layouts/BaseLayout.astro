---
// src/layouts/BaseLayout.astro
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { SITE, THEME } from "../lib/config";
import "../scripts/rum-core-web-vitals.ts";


type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  articleAuthor?: string;
  articleTags?: string[];
  articleSection?: string;
  robots?: string;
  twitterCreator?: string;  
};

const {
  title = "Adrián Mariscal",
  description = SITE.description ??
    "Rendimiento web, SEO técnico y UX con Astro y Node.",
  ogImage,
  ogType,
  articleAuthor,
  articleTags,
  articleSection,
  robots,
  twitterCreator,  
} = Astro.props as Props;

// Canonical absoluto usando siempre el dominio canónico del config de Astro
// (Astro.site se construye a partir de la opción `site` de astro.config.mjs)
const canonical = new URL(Astro.url?.pathname ?? "/", Astro.site).href;

// Detecta tipo automáticamente: 'article' en /blog/*, 'website' en el resto
const autoType = Astro.url?.pathname?.startsWith("/blog/") ? "article" : "website";
const type = ogType ?? autoType;

// Imagen OG (absoluta): prioriza prop > config por defecto
const rawImage = ogImage ?? SITE.ogImage ?? "/og-default.png";
const ogImageAbs = rawImage.startsWith("http")
  ? rawImage
  : new URL(rawImage, SITE.url).href;

// Locale + site name
const locale = "es_ES";
const siteName = SITE.siteName ?? "Portfolio - Adrián Mariscal";
const personId = `${SITE.url}#persona`;
const fontStylesheet =
  "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap";
const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": siteName,
      "url": SITE.url,
      "description": SITE.description,
      "inLanguage": SITE.lang ?? "es",
      "publisher": { "@id": personId },
    },
    {
      "@type": "Person",
      "@id": personId,
      "name": SITE.author,
      "url": SITE.url,
      "jobTitle": "Consultor de rendimiento web",
      "knowsAbout": [
        "Rendimiento web",
        "SEO técnico",
        "UX",
        "Astro",
        "Node.js",
      ],
    },
  ],
};
---

<!doctype html>
<html lang={SITE.lang ?? "es"} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
        <script>
      // Tema inicial: respeta localStorage y luego prefers-color-scheme
      (function () {
        const storageKey = 'am-theme';
        const root = document.documentElement;

        try {
          const stored = window.localStorage.getItem(storageKey);
          if (stored === 'light' || stored === 'dark') {
            root.dataset.theme = stored;
            return;
          }
        } catch (e) {
          /* si localStorage falla, seguimos con el modo por defecto */
        }

        // Modo oscuro por defecto; el claro queda como alternativa del toggle
        root.dataset.theme = 'dark';
      })();
    </script>

    <title>{title} — Adrián Mariscal</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={THEME.color} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="500x500" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="800x800" href="/logo_cuadrado.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonical} />
    {robots && <meta name="robots" content={robots} />}    

    <!-- Fuentes: preload del CSS crítico + swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontStylesheet} />
    <link
      rel="stylesheet"
      href={fontStylesheet}
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href={fontStylesheet} />
    </noscript>

    <!-- Open Graph -->
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content={title} />

    {type === "article" && (
      <>
        <meta
          property="article:author"
          content={articleAuthor ?? SITE.author}
        />
        {Array.isArray(articleTags) &&
          articleTags.map((tag) => (
            <meta property="article:tag" content={tag} />
          ))}
        <meta
          property="article:section"
          content={articleSection ?? "Blog"}
        />
      </>
    )}    

    <!-- Twitter (compatible con X/Twitter cards) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    {twitterCreator && (
      <meta name="twitter:creator" content={twitterCreator} />
    )}

    <!-- Schema.org (WebSite + Person) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schemaOrg, null, 2)}
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      Saltar al contenido principal
    </a>

    <Header />
    <main
      id="main-content"
      tabindex="-1"
      aria-label="Contenido principal"
    >
      <slot />
    </main>
    <CookieConsent />
    <Footer />
    {/* RUM propio de Core Web Vitals (LCP/INP/CLS) */}
    <script>
      import "../scripts/rum-core-web-vitals.ts";
    </script>
  </body>
</html>
