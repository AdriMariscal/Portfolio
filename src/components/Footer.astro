---
// src/components/Footer.astro
import pkg from '../../package.json' assert { type: 'json' };
import Button from './ui/Button.astro';
import NewsletterForm from './NewsletterForm.astro';

const year = new Date().getFullYear();
const version = pkg.version;

const legalLinks = [
  { href: '/legal/aviso-legal', label: 'Aviso legal' },
  { href: '/legal/privacidad', label: 'Privacidad' },
  { href: '/legal/cookies', label: 'Cookies' },
  { href: '/legal/terminos', label: 'Términos' },
];
---
<footer
  class="footer"
  role="contentinfo"
  aria-label="Información del sitio"
>
  <div class="wrap footer__inner">
    <a class="footer__brand" href="/" aria-label="Adrián Mariscal — Inicio">
      <img
        class="footer__logo"
        src="/logos/logo_cuadrado_transparente.svg"
        width="800"
        height="800"
        alt="Logo de Adrián Mariscal"
        decoding="async"
        loading="lazy"
      />
    </a>

    <NewsletterForm variant="compact" />

    <nav class="footer__nav" aria-label="Información legal">
      {legalLinks.map((l) => (
        <a class="footer__link" href={l.href}>{l.label}</a>
      ))}
    </nav>

    <Button
      type="button"
      variant="tertiary"
      size="sm"
      class="footer__link footer__link-btn"
      data-cookie-open-footer
      aria-label="Gestionar preferencias de cookies"
    >
      Gestionar cookies
    </Button>

    <div class="footer__copy">
      © {year} Adrián Mariscal · v{version}
    </div>
  </div>
</footer>
