---
// src/components/Header.astro
const normalize = (p: string) => {
  const s = p.replace(/\/+$/, "");
  return s === "" ? "/" : s;
};

const current = normalize(Astro.url.pathname);

const isActive = (href: string) => {
  const target = normalize(href);
  const active = current === target || current.startsWith(`${target}/`);
  return active ? "true" : undefined;
};
---

<header class="header" role="banner">
  <div class="wrap header__inner">
    <a class="brand" href="/" aria-label="Adrián Mariscal">
      <img
        class="brand__logo"
        src="/logo.png"
        width="1366"
        height="768"
        alt=""
        decoding="async"
      />
    </a>

    {/* Botón hamburguesa (solo se ve en móviles vía CSS) */}
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="main-navigation"
      aria-label="Abrir menú de navegación"
      data-nav-toggle
    >
      <span class="nav-toggle__icon" aria-hidden="true"></span>
    </button>

    <nav
      class="nav"
      data-nav
      id="main-navigation"
      aria-label="Navegación principal"
    >
      <a
        class="nav__link"
        href="/"
        aria-current={isActive("/")}
        aria-label="Ir a inicio"
      >
        <span class="nav__icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
          >
            <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
            <path
              d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
            />
          </svg>
        </span>
        <span>Inicio</span>
      </a>
      <a
        class="nav__link"
        href="/about"
        aria-current={isActive("/about")}
        aria-label="Ir a about"
      >
        <span class="nav__icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
          >
            <path d="M20 21a8 8 0 1 0-16 0" />
            <circle cx="12" cy="7" r="4" />
          </svg>
        </span>
        <span>About</span>
      </a>
      <a
        class="nav__link"
        href="/services"
        aria-current={isActive("/services")}
        aria-label="Ir a servicios"
      >
        <span class="nav__icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
          >
            <path d="M7 7h10v10H7z" />
            <path d="M14 4h6v6" />
            <path d="M10 20H4v-6" />
          </svg>
        </span>
        <span>Servicios</span>
      </a>
      <a
        class="nav__link"
        href="/projects"
        aria-current={isActive("/projects")}
        aria-label="Ir a proyectos"
      >
        <span class="nav__icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
          >
            <path
              d="m6 14 1.45-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.55 6a2 2 0 0 1-1.94 1.5H4a2 2 0 0 1-2-2V5c0-1.1.9-2 2-2h3.93a2 2 0 0 1 1.66.9l.82 1.2a2 2 0 0 0 1.66.9H18a2 2 0 0 1 2 2v2"
            />
            <circle cx="14" cy="15" r="1" />
          </svg>
        </span>
        <span>Proyectos</span>
      </a>
      <a
        class="nav__link"
        href="/blog"
        aria-current={isActive("/blog")}
        aria-label="Ir al blog"
      >
        <span class="nav__icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
          >
            <path d="M15 18h-5" />
            <path d="M18 14h-8" />
            <path
              d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-4 0v-9a2 2 0 0 1 2-2h2"
            />
            <rect width="8" height="4" x="10" y="6" rx="1" />
          </svg>
        </span>
        <span>Blog</span>
      </a>
      <a
        class="nav__link"
        href="/contact"
        aria-current={isActive("/contact")}
        aria-label="Ir a contacto"
      >
        <span class="nav__icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
          >
            <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7" />
            <rect x="2" y="4" width="20" height="16" rx="2" />
          </svg>
        </span>
        <span>Contacto</span>
      </a>

      <button
        class="theme-toggle"
        type="button"
        aria-label="Cambiar a tema claro"
        aria-pressed="true"
        data-theme-toggle
      >
        <span class="theme-toggle__icon" aria-hidden="true"></span>
        <span class="theme-toggle__label">Oscuro</span>
      </button>
    </nav>

  </div>
</header>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const nav = document.querySelector('[data-nav]');

  if (toggle && nav) {
    const handleToggle = () => {
      const isOpen = nav.classList.toggle('nav--open');
      toggle.classList.toggle('nav-toggle--open', isOpen);
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    };

    toggle.addEventListener('click', handleToggle);

    // Seguridad: al pasar a escritorio cerramos el menú móvil
    const mql = window.matchMedia('(min-width: 769px)');
    const handleMqChange = (event) => {
      if (event.matches) {
        nav.classList.remove('nav--open');
        toggle.classList.remove('nav-toggle--open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    };

    mql.addEventListener('change', handleMqChange);
  }

  // ==========================================================
  // Toggle de tema (claro / oscuro)
  // ==========================================================
  const themeToggle = document.querySelector('[data-theme-toggle]');
  if (themeToggle) {
    const storageKey = 'am-theme';
    const root = document.documentElement;

    const getCurrent = () =>
      root.dataset.theme === 'dark' ? 'dark' : 'light';

    const syncLabel = () => {
      const mode = getCurrent();
      const label = themeToggle.querySelector('.theme-toggle__label');
      if (label) {
        // Texto muestra la opción CONTRARIA a la actual
        label.textContent = mode === 'dark' ? 'Claro' : 'Oscuro';
      }
      themeToggle.setAttribute(
        'aria-label',
        mode === 'dark' ? 'Cambiar a tema claro' : 'Cambiar a tema oscuro'
      );
      themeToggle.setAttribute('aria-pressed', mode === 'dark' ? 'true' : 'false');
    };

    const setTheme = (next) => {
      root.dataset.theme = next;
      try {
        window.localStorage.setItem(storageKey, next);
      } catch (e) { /* ignoramos errores */ }
      syncLabel();
    };

    themeToggle.addEventListener('click', () => {
      const next = getCurrent() === 'dark' ? 'light' : 'dark';
      setTheme(next);
    });

    // Ajusta el texto inicial según el tema aplicado desde BaseLayout
    syncLabel();
  }

</script>
