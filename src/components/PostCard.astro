---
import type { CollectionEntry } from "astro:content";
import Card from "./ui/Card.astro";

const { entry, maxTags = 6 } = Astro.props as {
  entry: CollectionEntry<"blog">;
  maxTags?: number;
};

const { data, slug } = entry;

const tags: string[] = Array.isArray(data.tags) ? data.tags : [];
const tagSlice = tags.slice(0, maxTags);

const slugifyTag = (t: string) =>
  t
    .toLowerCase()
    .trim()
    .normalize("NFD")
    .replace(/\p{Diacritic}/gu, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

// Fecha formateada (si existe en el frontmatter)
// En tu MD la fecha viene como `date: 2025-11-27`, que Astro parsea a Date.
const rawDate = (data as any).date;
const date = rawDate ? new Date(rawDate as any) : undefined;

const formattedDate = date
  ? date.toLocaleDateString("es-ES", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    })
  : null;
---

<Card as="article" variant="post">
  <a
    class="card__overlay-link"
    href={`/blog/${slug}/`}
    aria-label={`Abrir artículo: ${data.title}`}
  ></a>
  <div class="card__body">
    <h3 class="card__title postcard__title">{data.title}</h3>

    {formattedDate && date && (
      <p class="postcard__date">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </p>
    )}

    {data.description && (
      <p class="postcard__excerpt">{data.description}</p>
    )}

    {tagSlice.length > 0 && (
      <ul class="taglist card__interactive" aria-label="Etiquetas">
        {tagSlice.map((t) => (
          <li>
            <a class="tag" href={`/blog/tags/${slugifyTag(t)}/`}>
              #{t}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Card>
