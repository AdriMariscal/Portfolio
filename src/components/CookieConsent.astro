---
// src/components/CookieConsent.astro

// No necesitamos props; el componente se autogestiona
import Button from "./ui/Button.astro";
const STORAGE_KEY = "am-cookie-consent-v1";
---

<div
  class="cookie-banner"
  data-cookie-banner
  hidden
  role="dialog"
  aria-modal="true"
  aria-labelledby="cookie-banner-title"
  tabindex="-1"
>
  <div class="wrap cookie-banner__inner">
    <div class="cookie-banner__content">
      <div class="cookie-banner__main">
        <h2 class="cookie-banner__title" id="cookie-banner-title">
          Preferencias de cookies
        </h2>
        <p class="cookie-banner__text">
          Solo uso cookies necesarias para que el sitio funcione. Si aceptas las
          analíticas, podré medir rendimiento y mejorar el contenido. Puedes
          ajustar tu elección cuando quieras.
        </p>

        <div class="cookie-banner__prefs" aria-label="Preferencias de cookies">
          <label class="cookie-banner__pref-label">
            <input
              type="checkbox"
              id="cookie-analytics"
              name="cookie-analytics"
              data-cookie-input="analytics"
              aria-label="Preferencias de cookies: analíticas"
            />
            <span>
              <strong>Analíticas</strong>
              <span class="cookie-banner__pref-desc">
                Ayudan a entender cómo se usa la web de forma agregada para
                mejorar contenido y rendimiento.
              </span>
            </span>
          </label>

          <label class="cookie-banner__pref-label">
            <input
              type="checkbox"
              id="cookie-marketing"
              name="cookie-marketing"
              data-cookie-input="marketing"
              aria-label="Preferencias de cookies: marketing"
            />
            <span>
              <strong>Marketing</strong>
              <span class="cookie-banner__pref-desc">
                Permiten mostrar campañas o contenido promocional si algún día
                las utilizo.
              </span>
            </span>
          </label>
        </div>

        <p class="cookie-banner__note">
          Consulta la política de
          <a class="cookie-banner__note-link" href="/legal/cookies">
            cookies
          </a>.
        </p>
      </div>

      <div class="cookie-banner__actions">
        <Button
          type="button"
          variant="secondary"
          size="sm"
          data-cookie-reject
          aria-label="Rechazar cookies no necesarias"
        >
          Solo necesarias
        </Button>
        <Button
          type="button"
          variant="primary"
          size="sm"
          data-cookie-accept-selected
          aria-label="Guardar preferencias de cookies"
        >
          Guardar preferencias
        </Button>
        <Button
          type="button"
          variant="tertiary"
          size="sm"
          class="cookie-banner__link"
          data-cookie-accept-all
          aria-label="Aceptar todas las cookies"
        >
          Aceptar todas
        </Button>
      </div>
    </div>
  </div>
</div>

<script is:inline type="module" src="/scripts/cookie-consent-ui.js"></script>
